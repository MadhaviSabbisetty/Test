  // ================= STATE =================
  const [branches, setBranches] = useState([]);
  const [cgls, setCgls] = useState([]);

  const [loading, setLoading] = useState({
    branch: false,
    cgl: false,
  });

  const [req, setReq] = useState({
    branch: true,
    cgl: true,
  });

  // const [sourceOptions, setSourceOptions] = useState([]);

  // ================= SEARCH OPTIONS =================
  const setSearchOptions = (type, data) => {
    if (type === "branch") setBranches(data);
    if (type === "cgl") setCgls(data);
  };

  // // ================= API CALL =================
  const fetchSearchData = useCallback(
    async (type, term) => {
      try {
        setLoading((p) => ({ ...p, [type]: true }));

        let circleValue =
          permissions?.wholebank === true
            ? "null"
            : user?.isCircle === true || permissions?.circle
              ? user?.circleCode
              : "";

        const url =
          type === "branch"
            ? `/CM/common-master/branches-code-name-only?q=${encodeURIComponent(term)}&circleCode=${circleValue || ""}`
            : `/CM/common-master/cgl-code-description-only?q=${encodeURIComponent(term)}`;

        const result = await callApi(url, null, "GET");
        let options = [];

        if (result?.data?.length > 0) {
          result.data.forEach((item) => {
            options.unshift(
              type === "branch"
                ? `${item.code}-${item.name}`
                : `${item.cglNumber} - ${item.description}`,
            );
          });
          setSearchOptions(type, options);
        } else {
          showSnackBar("Data is not available");
        }
      } catch (e) {
        console.error(e);
      } finally {
        setLoading((p) => ({ ...p, [type]: false }));
      }
    },
    [callApi, permissions, user, showSnackBar],
  );

  // ================= INPUT HANDLER =================
  const handleSearchChange = (value = null, reason, type) => {
    if (reason === "input") {
      const val = value || "";
      if (val.length >= 3) {
        setReq((prev) => ({ ...prev, [type]: false }));
        fetchSearchData(type, val);
      } else {
        setReq((prev) => ({ ...prev, [type]: true }));
        // DELETE THIS LINE: fetchSearchData.cancel();
      }
    } else if (reason === "clear") {
      setReq((prev) => ({ ...prev, [type]: true }));
    }
  };

  const isNumeric = (value) => {
    if (value) {
      const regex = /^\d+$/;
      return regex.test(value);
    }
    return false;
  };

  // ================= EFFECTS =================
  useEffect(() => {
    if (req.branch) {
      setBranches([]);
    }
  }, [req.branch]);

  useEffect(() => {
    fetchCurrencies();
  }, [fetchCurrencies]);

  useEffect(() => {
    if (req.cgl) {
      setCgls([]);
    }
  }, [req.cgl]);

  // ================= UI =================
  return (
    <>
      <StyledStack direction="row">
        {/* BRANCH */}
        <StyledFormBox sx={{ flex: 1 }}>
          <Autocomplete
            // disabled={user?.isCircle === "false" || permissions.branch}
            disabled={
              !permissions?.wholebank &&
              (user?.isCircle === false || permissions?.branch)
            }
            forcePopupIcon={false}
            autoHighlight
            value={userInputs?.branch || ""}
            loading={!req.branch && loading.branch}
            options={branches}
            noOptionsText={
              req.branch ? "Please enter at least 3 characters" : "No Options"
            }
            onInputChange={(e, value, reason) => {
              handleSearchChange(value, reason, "branch");
            }}
            onChange={(e, value) => update("branch", value)}
            renderInput={(params) => (
              <TextField
                {...params}
                label="Branch Code or Branch Name*"
                placeholder="eg. 12365 or ABC"
                InputLabelProps={{ shrink: true }}
                slotProps={{
                  htmlInput: {
                    ...params.inputProps,
                    maxLength: isNumeric(params.inputProps.value) ? 5 : 15,
                  },
                }}
                sx={{
                  "& .MuiInputLabel-root": {
                    fontWeight: 500,
                    color: "text.primary",
                  },
                  "& .MuiOutlinedInput-root": {
                    backgroundColor: "transparent",
                  },
                }}
              />
            )}
          />
        </StyledFormBox>

        {/* CURRENCY */}
        <StyledFormBox sx={{ flex: 1 }}>
          <Autocomplete
            options={currencies || []}
            value={userInputs?.currency || null}
            onOpen={fetchCurrencies}
            onChange={(event, newValue) => update("currency", newValue)}
            renderInput={(params) => (
              <TextField
                {...params}
                label="Currency*"
                InputLabelProps={{ shrink: true }}
                placeholder="Select Currency"
                sx={{
                  "& .MuiInputLabel-root": {
                    fontWeight: 500,
                    color: "text.primary",
                  },
                  "& .MuiOutlinedInput-root": {
                    backgroundColor: "transparent",
                  },
                }}
              />
            )}
          />
        </StyledFormBox>

        {/* CGL */}
        <StyledFormBox sx={{ flex: 1 }}>
          <Autocomplete
            forcePopupIcon={false}
            autoHighlight
            value={userInputs?.cgl || ""}
            loading={!req.cgl && loading.cgl}
            options={cgls}
            noOptionsText={
              req.cgl ? "Please enter at least 3 characters" : "No Options"
            }
            onInputChange={(e, value, reason) => {
              handleSearchChange(value, reason, "cgl");
            }}
            onChange={(e, value) => update("cgl", value)}
            renderInput={(params) => (
              <TextField
                {...params}
                label="CGL*"
                InputLabelProps={{ shrink: true }}
                placeholder="eg. 9999999999"
                sx={{
                  "& .MuiInputLabel-root": {
                    fontWeight: 500,
                    color: "text.primary",
                  },
                  "& .MuiOutlinedInput-root": {
                    backgroundColor: "transparent",
                  },
                }}
                slotProps={{
                  htmlInput: {
                    ...params.inputProps,
                    maxLength: isNumeric(params.inputProps.value) ? 10 : 30,
                  },
                }}
              />
            )}
          />
        </StyledFormBox>

        {/* SOURCE FLAG */}
        <StyledFormBox sx={{ flex: 1 }}>
          <Autocomplete
            multiple
            disableCloseOnSelect
            forcePopupIcon={true}
            openOnFocus
            options={sourceOptions}
            value={userInputs?.sourceFlags || []}
            isOptionEqualToValue={(opt, val) => opt.flagId === val.flagId}
            getOptionLabel={(opt) => opt.flagName || ""}
            renderTags={(value, getTagProps) => {
              const allSelected = value.length === sourceOptions.length;

              if (allSelected) {
                return (
                  <Typography
                    variant="body2"
                    sx={{
                      fontWeight: 500,
                      color: "text.secondary",
                      ml: 0.5,
                    }}
                  >
                    Select All
                  </Typography>
                );
              }

              if (value.length === 0) return null;

              const moreCount = value.length - 1;

              const { onDelete: _onDelete, ...tagProps } = getTagProps({
                index: 0,
              });

              return (
                <Box
                  sx={{
                    display: "flex",
                    alignItems: "center",
                    gap: 0.5,
                  }}
                >
                  <Chip
                    {...tagProps}
                    key={value[0].flagId}
                    label={value[0].flagName}
                    size="small"
                    sx={{
                      borderRadius: "6px",
                      pointerEvents: "none",
                      height: "24px",
                    }}
                  />

                  {moreCount > 0 && (
                    <Typography
                      variant="caption"
                      sx={{
                        fontWeight: 600,
                        color: "text.secondary",
                        whiteSpace: "nowrap",
                      }}
                    >
                      +{moreCount} more
                    </Typography>
                  )}
                </Box>
              );
            }}
            onChange={(e, newValue) => {
              if (newValue.find((option) => option.flagId === "all")) {
                const isAllSelected =
                  userInputs?.sourceFlags?.length === sourceOptions.length;
                update("sourceFlags", isAllSelected ? [] : sourceOptions);
              } else {
                update("sourceFlags", newValue);
              }
            }}
            filterOptions={(options) => [
              { flagId: "all", flagName: "Select All" },
              ...options,
            ]}
            renderOption={(props, option, { selected }) => {
              const { key, ...optionProps } = props;
              const isSelectAll = option.flagId === "all";
              const allSelected =
                userInputs?.sourceFlags?.length === sourceOptions.length;
              return (
                <li key={key} {...optionProps} style={{ fontSize: "0.875rem" }}>
                  <Checkbox
                    size="small"
                    style={{ marginRight: 8 }}
                    checked={isSelectAll ? allSelected : selected}
                  />
                  <Typography
                    variant="body2"
                    sx={{ fontWeight: isSelectAll ? 600 : 400 }}
                  >
                    {option.flagName}
                  </Typography>
                </li>
              );
            }}
            renderInput={(params) => (
              <TextField
                {...params}
                label="Transaction Type*"
                placeholder={
                  userInputs?.sourceFlags?.length > 0 ? "" : "Select Options"
                }
                InputLabelProps={{ shrink: true }}
                sx={{
                  "& .MuiInputLabel-root": {
                    fontWeight: 500,
                    color: "text.primary",
                  },
                  "& .MuiOutlinedInput-root": {
                    backgroundColor: "transparent",
                    minHeight: "56px !important",
                    height: "56px !important",
                    display: "flex",
                    alignItems: "center",
                    flexWrap: "nowrap !important",
                    overflow: "hidden",
                    cursor: "pointer",
                    paddingRight: "65px !important",
                    "& .MuiAutocomplete-input": {
                      padding: "0px !important",
                      minWidth: "0px !important",
                    },
                    "& .MuiAutocomplete-endAdornment": {
                      top: "50%",
                      transform: "translateY(-50%)",
                      display: "flex",
                      alignItems: "center",
                      right: "8px",
                    },
                  },
                }}
              />
            )}
          />
        </StyledFormBox>

        <Stack direction="row" sx={{ flexGrow: 1 }}>
          {/* FROM AMOUNT */}
          <StyledFormBox sx={{ flex: 1 }}>
            <TextField
              label="From Amount"
              InputLabelProps={{ shrink: true }}
              fullWidth
              placeholder="eg. 0.00"
              value={userInputs?.minAmount || ""}
              onPaste={(e) => e.preventDefault()}
              onChange={(e) => {
                const val = e.target.value;
                if (val === "" || /^\d*\.?\d*$/.test(val))
                  update("minAmount", val);
              }}
              inputProps={{ maxLength: 20, inputMode: "decimal" }}
              sx={{
                "& .MuiInputLabel-root": {
                  fontWeight: 500,
                  color: "text.primary",
                },
                "& .MuiOutlinedInput-root": { backgroundColor: "transparent" },
              }}
            />
          </StyledFormBox>

          {/* TO AMOUNT */}
          <StyledFormBox sx={{ flex: 1 }}>
            <TextField
              label="To Amount"
              InputLabelProps={{ shrink: true }}
              fullWidth
              placeholder="eg. 999999999..."
              value={userInputs?.maxAmount || ""}
              onPaste={(e) => e.preventDefault()}
              onChange={(e) => {
                const val = e.target.value;
                if (val === "" || /^\d*\.?\d*$/.test(val))
                  update("maxAmount", val);
              }}
              inputProps={{ maxLength: 20, inputMode: "decimal" }}
              sx={{
                "& .MuiInputLabel-root": {
                  fontWeight: 500,
                  color: "text.primary",
                },
                "& .MuiOutlinedInput-root": { backgroundColor: "transparent" },
              }}
            />
          </StyledFormBox>

          {/* START DATE */}
          <LocalizationProvider dateAdapter={AdapterDayjs}>
            <StyledFormBox sx={{ flex: 1 }}>
              <DatePicker
                disableHighlightToday
                value={userInputs?.fromDate || null}
                // onChange={(v) => update("fromDate", v)}
                onChange={(v) => {
                  update("fromDate", v);
                  if (
                    userInputs?.toDate &&
                    v &&
                    userInputs?.toDate.isBefore(v)
                  ) {
                    update("toDate", null);
                  }
                }}
                format="DD-MM-YYYY"
                minDate={dayjs("2026-03-31")}
                maxDate={etlDate}
                slotProps={{
                  textField: {
                    label: "From Date*",
                    fullWidth: true,
                    InputLabelProps: { shrink: true },
                    readOnly: true,
                    sx: {
                      "& .MuiInputLabel-root": {
                        fontWeight: 500,
                      },
                      "& .MuiInputBase-input": { caretColor: "transparent" },
                    },
                  },
                }}
              />
            </StyledFormBox>
            <StyledFormBox sx={{ flex: 1 }}>
              <DatePicker
                disableHighlightToday
                value={userInputs?.toDate || null}
                onChange={(v) => update("toDate", v)}
                format="DD-MM-YYYY"
                disabled={!userInputs?.fromDate}
                minDate={dayjs(userInputs.fromDate)}
                maxDate={etlDate}
                slotProps={{
                  textField: {
                    label: "To Date*",
                    fullWidth: true,
                    InputLabelProps: { shrink: true },
                    readOnly: true,
                    sx: {
                      "& .MuiInputLabel-root": {
                        fontWeight: 500,
                      },
                      "& .MuiInputBase-input": { caretColor: "transparent" },
                    },
                  },
                }}
              />
            </StyledFormBox>
          </LocalizationProvider>
        </Stack>
      </StyledStack>

      {/* BUTTONS */}
      <ButtonBox sx={{ mt: 2 }}>
        <Button
          variant="contained"
          onClick={resetState}
          startIcon={<RestartAltIcon />}
        >
          Reset
        </Button>
        &nbsp;&nbsp;
        <Button
          variant="contained"
          startIcon={<SearchIcon />}
          disabled={
            !(
              userInputs?.branch &&
              userInputs?.currency &&
              userInputs?.cgl &&
              userInputs?.fromDate?.isValid?.() &&
              userInputs?.toDate?.isValid?.() &&
              !userInputs.toDate.isBefore(userInputs.fromDate) &&
              userInputs?.sourceFlags?.length > 0
            )
          }
          onClick={onSubmit}
        >
          Search
        </Button>
      </ButtonBox>
    </>
  );
};

