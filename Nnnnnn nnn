const TransactionEnquiryScreen = () => {
  const { callApi } = useApi();
  const snackbar = useCustomSnackbar();

  const user = useSelector((state) => state.auth.user);

  const [currencies, setCurrencies] = useState([]);
  const [data, setData] = useState(null);
  const [sourceOptions, setSourceOptions] = useState([]);
  const [etlDate, setEtlDate] = useState(null);
  const [loading, setLoading] = useState(false);
  const [exportLoading , setExportLoading] = useState(false);
  const [searchLoading ,setSearchLoading] =useState(false);

  const [filtersExpanded, setFiltersExpanded] =
    useState(true);

  const [userInputs, setUserInputs] = useState({
    branch:
      user?.isCircle === false
        ? `${user.branch}-${user.branchName}`
        : "",
    currency: null,
    cgl: "",
    fromDate: null,
    toDate: null,
    minAmount: "",
    maxAmount: "",
    sourceFlags: [],
  });

  const fetchCurrencies = useCallback(async () => {
    const res = await callApi(
      "/CM/common-master/currency-code-name-only",
      null,
      "GET"
    );

    const formattedCurrencies =
      res?.data?.map(
        (c) =>
          `${c.currencyCode} (${c.currencyName})`
      ) || [];

    const sortedCurrencies =
      formattedCurrencies.sort((a, b) => {
        if (a.startsWith("INR")) return -1;
        if (b.startsWith("INR")) return 1;
        return a.localeCompare(b);
      });

    setCurrencies(sortedCurrencies);
  }, [callApi]);

  const [rowCount, setRowCount] = useState(0);

  const [paginationModel, setPaginationModel] =
    useState({
      page: 0,
      pageSize:25,
    });

  const fetchTransactions = useCallback(async () => {
    try {
      if (!areUserInputsValid(userInputs)) return;

      setLoading(true);

      const payload = {
        branch:
          userInputs?.branch?.split(" (")[0],
        currency:
          userInputs?.currency?.split(" (")[0],
        cgl:
          userInputs?.cgl?.split(" - ")[0],
        fromDate: dayjs(
          userInputs?.fromDate
        ).format("DD/MM/YYYY"),
        toDate: dayjs(
          userInputs?.toDate
        ).format("DD/MM/YYYY"),
        minAmount: userInputs.minAmount
          ? Number(userInputs.minAmount)
          : null,
        maxAmount: userInputs.maxAmount
          ? Number(userInputs.maxAmount)
          : null,
        sourceFlags: (
          userInputs.sourceFlags || []
        ).map((item) => item.flagId),
        page: paginationModel.page,
        size: paginationModel.pageSize,
      };

      setSearchLoading(true);

      const res = await callApi(
        "/ES/transaction-con/transactions",
        payload,
        "POST"
      );

      if (res?.data?.length > 0) {
        setData(res);
        setFiltersExpanded(false);
        setRowCount(res.totalElements || 0);
      } else {
        setData({
          data: [],
          extraData: null,
        });
        setRowCount(0);
      }
    } catch {
      snackbar(
        "Failed to fetch transactions",
        "error"
      );
    } finally {
      setLoading(false);
      setSearchLoading(false);
    }
  }, [
    userInputs,
    callApi,
    paginationModel,
    snackbar,
  ]);

  const handleDownload = async () => {
    try{
      setExportLoading(true);
    const payload = {
      branch:
        userInputs?.branch
          ?.split("-")[0]
          .trim(),
      currency:
        userInputs?.currency?.split(" (")[0],
      cgl:
        userInputs?.cgl?.split(" -")[0],
      fromDate: dayjs(
        userInputs?.fromDate
      ).format("DD/MM/YYYY"),
      toDate: dayjs(
        userInputs?.toDate
      ).format("DD/MM/YYYY"),
      minAmount: userInputs.minAmount
        ? Number(userInputs.minAmount)
        : null,
      maxAmount: userInputs.maxAmount
        ? Number(userInputs.maxAmount)
        : null,
      sourceFlags: (
        userInputs.sourceFlags || []
      ).map((item) => item.flagId),
    };

    const res = await callApi(
      "/ES/transaction-con/transactions-download",
      payload,
      "POST",
      "arraybuffer"
    );

    if (res?.byteLength) {
      downloadFile(
        res,
        "excel",
        "transactions"
      );
    }
  } finally {
    setExportLoading(false);
  }
  };

  useEffect(() => {
    if (rowCount > 0) fetchTransactions();
  }, [
    paginationModel.page,
    paginationModel.pageSize,
    // fetchTransactions,
    // rowCount,
  ]);

  const resetState = () => {
    setData(null);
    setRowCount(0);
    setLoading(false);

    // NEW
    setFiltersExpanded(true);

    setUserInputs({
      branch: "",
      currency: null,
      cgl: "",
      fromDate: null,
      toDate: null,
      minAmount: "",
      maxAmount: "",
      sourceFlags:[
        {
          flagId:"ALL",
          flagName: "Select All",
        },
      ],
    });

    setPaginationModel({
      page: 0,
      pageSize: 10,
    });
  };

  // Date Requirement
useEffect(() => {
  const fetchSystemDate = async () => {
    try {
      const dateRes = await callApi("/PS/file/fincore-date", {}, "GET");
      
      const etlRaw = dateRes?.data?.userDate;
      const etl = etlRaw ? dayjs(etlRaw.split("T")[0]) : dayjs();
      // const startDate = dayjs("2026-03-31");

      setEtlDate(etl);
      // setUserInputs((prev) => ({
      //   ...prev,
      //   fromDate: startDate,
      //   toDate: etl,
      // }));
    } catch (e) {
      console.error("System Date Fetch Error:", e);
    }
  };
  fetchSystemDate();
}, [callApi]); 


  useEffect(() => {
