import dayjs from "dayjs";

export const branchRegex = /^[a-zA-Z0-9()\-_ ]+$/;
export const currencyRegex = /^[a-zA-Z()\-_ ]+$/;
export const cglRegex = /^[a-zA-Z0-9()\-_ ]+$/; 

export const areUserInputsValid = (userInputs) => {
  
  const branchCode = userInputs?.branch?.split(' - ')[0];
  const currencyCode = userInputs?.currency?.split(' (')[0];
  const cglNumber = userInputs?.cgl?.split(' - ')[0];
  
  const fromDate = userInputs?.fromDate;
  const toDate = userInputs?.toDate;

  const min = userInputs.minAmount ? Number(userInputs.minAmount) : null;
  const max = userInputs.maxAmount ? Number(userInputs.maxAmount) : null;
  // Valid if: both are empty, only one is filled, or min <= max
  const isAmtValid = (min !== null && max !== null) ? min <= max : true;

  if (!branchCode || !currencyCode || !cglNumber || !fromDate || !toDate) return false;

  return (
    branchRegex.test(branchCode) &&
    currencyRegex.test(currencyCode) &&
    cglRegex.test(cglNumber) &&
    (dayjs(fromDate).isSame(dayjs(toDate)) || dayjs(fromDate).isBefore(dayjs(toDate))) &&
    isAmtValid 
  );
};

