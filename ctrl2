package com.fincore.analyticsservice.repository;

import com.fincore.analyticsservice.model.DrReportView;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;

import java.util.Optional;

@Repository
public interface DrReportViewRepository extends JpaRepository<DrReportView, Long> {

    /**
     * Fetches the View configuration and its mapped physical Druid datasource.
     * Dimensions and metrics collections are fetched sequentially in the transactional
     * service layer to avoid Cartesian product generation (MultipleBagFetchException).
     */
    @Query("""
                SELECT v FROM DrReportView v
                JOIN FETCH v.datasource
                WHERE v.viewCode = :viewCode AND v.active = true
            """)
    Optional<DrReportView> findByViewCodeActive(@Param("viewCode") String viewCode);
}
