package com.fincore.analyticsservice.repository;

import com.fincore.analyticsservice.model.DrReport;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.stereotype.Repository;

import java.util.List;

@Repository
public interface DrReportRepository extends JpaRepository<DrReport, Long> {

    /**
     * Enterprise Optimization:
     * We use JOIN FETCH to load the Parent (Report) and Child (Views) in a single DB trip.
     * The dimensions and metrics will be lazy-loaded in the service layer, but because
     * this method is cached in Redis, the DB is only hit once globally.
     */
    @Query("SELECT DISTINCT r FROM DrReport r JOIN FETCH r.views v WHERE r.active = true AND v.active = true")
    List<DrReport> findAllActiveReportsWithViews();
}
