package com.fincore.ReportService.service;

import com.fincore.ReportService.dto.AsciiFileRequest;
import com.fincore.ReportService.dto.AsciiFileResponse;
import com.fincore.ReportService.dto.AsciiTypeResponse;
import com.fincore.ReportService.dto.BranchResponse;
import com.fincore.ReportService.model.AsciiMaster;
import com.fincore.ReportService.model.BranchMaster;
import com.fincore.ReportService.repository.AsciiMasterRepository;
import com.fincore.ReportService.repository.BranchMasterRepository;
import com.fincore.ReportService.service.AsciiFileService;
import com.fincore.ReportService.service.HdfsService;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

import org.apache.hadoop.fs.FSDataInputStream;
import org.apache.hadoop.fs.FileSystem;
import org.apache.hadoop.fs.Path;

import org.springframework.http.HttpHeaders;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import java.io.BufferedReader;
import java.io.InputStreamReader;
import java.nio.charset.StandardCharsets;
import java.util.*;


@Service
@RequiredArgsConstructor
@Slf4j
public class AsciiFileServiceImpl implements AsciiFileService {

    private final AsciiMasterRepository asciiMasterRepository;

    private final BranchMasterRepository branchMasterRepository;

    private final HdfsService hdfsService;

    @Override
    public List<AsciiTypeResponse> getAsciiTypes(){

        return asciiMasterRepository.findAll()
            .stream()
            .map(a->
                    new AsciiTypeResponse(
                        a.getId(),
                        a.getReportName()
                    ))
                    .toList();
    }


    @Override
    public List<BranchResponse> getBranches(){

        return branchMasterRepository.findAll()
            .stream()
            .map(b->
                    new BranchResponse(
                        b.getCode(),
                        b.getName()
                    ))
                    .toList();
    }


    @Override
    public AsciiFileResponse viewAscii(AsciiFileRequest request) {

        try {

            log.info("ASCII VIEW REQUEST : {}", request);

            AsciiMaster master =
                    asciiMasterRepository.findById(request.getId())
                            .orElseThrow(() ->
                                    new RuntimeException("Invalid ASCII ID:"+request.getId()));

            String hdfsPath = buildFilePath(master, request);

            log.info("FINAL HDFS PATH : {}", hdfsPath);

            FileSystem fs = hdfsService.getFs();

            Path path = new Path(hdfsPath);
            log.info("checking file existence....");

            boolean fileExists=fs.exists(path);
            log.info("file exists:{}",fileExists);

            if(!fileExists){
                AsciiFileResponse response=new AsciiFileResponse();
                response.setId(request.getId());
                response.setReportDate(request.getReportDate());
                response.setSearchBy(request.getSearchBy());

                if("branch".equalsIgnoreCase(request.getSearchBy())){
                    response.setBranchCode(request.getBranchCode());
                }
                response.setContent("ASCII File not found");
                return response;
            // if (!fs.exists(path)) {
               // throw new RuntimeException("ASCII File not found : " + hdfsPath);
            }

            StringBuilder content = new StringBuilder();

            try (FSDataInputStream inputStream = fs.open(path);
                 BufferedReader reader =
                         new BufferedReader(new InputStreamReader(inputStream))) {

                String line;

                while ((line = reader.readLine()) != null) {
                    content.append(line)
                           .append(System.lineSeparator());
                }
            }

            AsciiFileResponse response = new AsciiFileResponse();

            response.setId(request.getId());
            response.setReportDate(request.getReportDate());
            response.setSearchBy(request.getSearchBy());

            if ("branch".equalsIgnoreCase(request.getSearchBy())) {
                response.setBranchCode(request.getBranchCode());
            }

            response.setContent(content.toString());

            return response;

        } catch (Exception e) {

            log.error("Error while viewing ascii file", e);

            throw new RuntimeException(e.getMessage());
        }
    }

    @Override
    public ResponseEntity<byte[]> downloadAscii(AsciiFileRequest request) {

        try {

            AsciiMaster master =
                    asciiMasterRepository.findById(request.getId())
                            .orElseThrow(() ->
                                    new RuntimeException("Ascii Master not found"));

            String hdfsPath = buildFilePath(master, request);

            FileSystem fs = hdfsService.getFs();

            Path path = new Path(hdfsPath);

            if (!fs.exists(path)) {
                throw new RuntimeException("ASCII File not found");
            }

            FSDataInputStream inputStream = fs.open(path);

            byte[] fileContent =
                    inputStream.readAllBytes();

            inputStream.close();

            String fileName = path.getName();

            return ResponseEntity.ok()
                    .header(
                            HttpHeaders.CONTENT_DISPOSITION,
                            "attachment; filename=" + fileName)
                    .contentType(MediaType.TEXT_PLAIN)
                    .body(fileContent);

        } catch (Exception e) {

            log.error("Error while downloading ascii file", e);

            throw new RuntimeException(e.getMessage());
        }
    }

    private String buildFilePath(
            AsciiMaster master,
            AsciiFileRequest request) {
        
        if
        ("branch".equalsIgnoreCase(request.getSearchBy())
        && (request.getBranchCode()==null 
        || request.getBranchCode().isBlank())){
            throw new RuntimeException("Branch code is mandatory for branch search");
        }

        String dateFolder = request.getReportDate();

        String fileDate =
                request.getReportDate().replace("-", "");

        String location =
                master.getLocation()
                        .replace("{date}", dateFolder);

        String branchCode =
                "bank".equalsIgnoreCase(request.getSearchBy())
                        ? "00000"
                        : request.getBranchCode();

        log.info("report date:{}",dateFolder);
        log.info("location:{}",location);
        log.info("branch code:{}",branchCode);
        

        String fileName;

        switch (request.getId().intValue()) {

            case 101:
                fileName =
                        branchCode + ".INR." +
                                fileDate + ".CWP";
                break;

            case 102:
                fileName =
                        branchCode + ".INR." +
                                fileDate + ".WK";
                break;

            case 103:
                fileName =
                        branchCode + ".YSA." +
                                fileDate;
                break;

            case 104:
                fileName =
                        branchCode + ".PL." +
                                fileDate;
                break;

            case 105:
                fileName =
                        branchCode + ".TBY." +
                                fileDate;
                break;

            case 106:
                fileName =
                        branchCode + ".TBP." +
                                fileDate;
                break;
            
            case 107:
                fileName =
                        branchCode + ".TBNWSA." +
                                fileDate;
                break;

            default:
                throw new RuntimeException("Invalid ASCII ID");
        }
        log.info("file name:{}",fileName);
        String  finalPath="/" + location + "/" + fileName;
        log.info("final path: {}",finalPath);
        return finalPath;

        // return "/" + location + "/" + fileName;
    }
} 



package com.fincore.ReportService.controller;

import java.io.IOException;
import java.util.List;
import java.util.Map;

import com.fincore.ReportService.dto.*;
import com.fincore.commonutilities.jwt.JwtUtil;
import lombok.extern.slf4j.Slf4j;

import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestHeader;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;
import org.springframework.http.HttpHeaders;
import org.springframework.http.MediaType;
import org.springframework.web.servlet.mvc.method.annotation.StreamingResponseBody;

import com.fincore.ReportService.service.AsciiFileService;
import lombok.RequiredArgsConstructor;
import org.springframework.web.bind.annotation.GetMapping;

@Slf4j
@RestController
@RequestMapping("/api/ascii")
@RequiredArgsConstructor
public class AsciiFileController {

    private final AsciiFileService asciiFileService;

    @GetMapping("/file-types")
    public ResponseEntity<List<AsciiTypeResponse>> getAsciiTypes(){
        return ResponseEntity.ok(
            asciiFileService.getAsciiTypes()
        );
    }

    @GetMapping("/branches")
    public ResponseEntity<List<BranchResponse>> getBranches(){
        return ResponseEntity.ok(
            asciiFileService.getBranches()
        );
    }

    @PostMapping("/view")
    public ResponseEntity<ApiResponse<AsciiFileResponse>> viewAscii(
            @RequestBody AsciiFileRequest request) {

        AsciiFileResponse response =
                asciiFileService.viewAscii(request);
        
        if("ASCII File not found".equals(response.getContent())){
            return ResponseEntity.ok(
                ApiResponse.success(response,"ASCII file not found")
            );
        }

        return ResponseEntity.ok(
                ApiResponse.success(response,"ASCII file fetched successfully")
        );
    }

    @PostMapping("/download")
    public ResponseEntity<byte[]> downloadAscii(
            @RequestBody AsciiFileRequest request) {

        return asciiFileService.downloadAscii(request);
    }
}
