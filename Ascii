package com.fincore.ReportService.service;

import com.fincore.ReportService.dto.AsciiFileRequest;
import com.fincore.ReportService.dto.AsciiFileResponse;
import com.fincore.ReportService.dto.AsciiTypeResponse;
import com.fincore.ReportService.model.AsciiMaster;
import com.fincore.ReportService.model.AsciiConfig;
import com.fincore.ReportService.model.AsciiConfigTb;
import com.fincore.ReportService.repository.AsciiMasterRepository;
import com.fincore.ReportService.repository.AsciiConfigRepository;
import com.fincore.ReportService.repository.AsciiConfigTbRepository;
import com.fincore.ReportService.service.AsciiFileService;
import com.fincore.ReportService.service.HdfsService;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

import org.apache.hadoop.fs.FSDataInputStream;
import org.apache.hadoop.fs.FileSystem;
import org.apache.hadoop.fs.Path;

import org.springframework.http.HttpHeaders;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;

import java.io.BufferedReader;
import java.io.InputStreamReader;
import java.nio.charset.StandardCharsets;
import java.util.*;

import java.time.LocalDate;
import java.time.format.DateTimeFormatter;


@Service
@RequiredArgsConstructor
@Slf4j
public class AsciiFileServiceImpl implements AsciiFileService {

    private final AsciiMasterRepository asciiMasterRepository;

    private final AsciiConfigRepository asciiConfigRepository;

    private final AsciiConfigTbRepository asciiConfigTbRepository;

    private final HdfsService hdfsService;

    @Override
    public List<AsciiTypeResponse> getAsciiTypes(){

        // return asciiMasterRepository.findAll()
        log.info("API called - into service");
        List<AsciiTypeResponse> response=asciiMasterRepository.findAll()
            .stream()
            .map(a->
                    new AsciiTypeResponse(
                        a.getId(),
                        a.getReportName()
                    ))
                    .toList();
                    if(response.isEmpty()){
                        throw new IllegalArgumentException("No ASCII file types found");
                    }
                    return response;
    }


    @Override
    public AsciiFileResponse viewAscii(AsciiFileRequest request) {

        try {

            log.info("ASCII VIEW REQUEST : {}", request);

            AsciiMaster master =
                    asciiMasterRepository.findById(request.getId())
                            .orElseThrow(() ->
                                    new IllegalArgumentException("Invalid ASCII ID"));

            String hdfsPath = buildFilePath(master, request);

            log.info("FINAL HDFS PATH : {}", hdfsPath);

            FileSystem fs = hdfsService.getFs();

            Path path = new Path(hdfsPath);
            log.info("checking file existence....");

            boolean fileExists=fs.exists(path);
            log.info("file exists:{}",fileExists);

            if (!fs.exists(path)) {
               throw new IllegalArgumentException("ASCII File not found");
            }

            StringBuilder content = new StringBuilder();

            try (FSDataInputStream inputStream = fs.open(path);
                 BufferedReader reader = new BufferedReader(new InputStreamReader(inputStream))) {

                String line;

                while ((line = reader.readLine()) != null) {
                    content.append(line)
                           .append(System.lineSeparator());
                }
            }

            AsciiFileResponse response = new AsciiFileResponse();

            response.setId(request.getId());
            response.setReportDate(request.getReportDate());
            response.setSearchBy(request.getSearchBy());

            if ("branch".equalsIgnoreCase(request.getSearchBy())) {
                response.setBranchCode(request.getBranchCode());
            }

            response.setContent(content.toString());

            return response;

        } catch (Exception e) {

            log.error("Error while viewing ascii file", e);

            throw new IllegalArgumentException(e.getMessage());
        }
    }

    @Override
    public ResponseEntity<byte[]> downloadAscii(AsciiFileRequest request) {

        try {

            AsciiMaster master =
                    asciiMasterRepository.findById(request.getId())
                            .orElseThrow(() ->
                                    new IllegalArgumentException("Invalid ASCII ID"));

            String hdfsPath = buildFilePath(master, request);

            FileSystem fs = hdfsService.getFs();

            Path path = new Path(hdfsPath);

            if (!fs.exists(path)) {
                throw new IllegalArgumentException("Failed to download. ASCII File not found");
            }

            FSDataInputStream inputStream = fs.open(path);

            byte[] fileContent =inputStream.readAllBytes();
            
            inputStream.close();

            String fileName = path.getName();

            log.info("Download response preparing for file: {}",fileName);
            log.info("File size :{} bytes",fileContent.length);

            log.info("Download response sent successfully");
 
            return ResponseEntity.ok()
                    .header(
                            HttpHeaders.CONTENT_DISPOSITION,
                            "attachment; filename=\"" + fileName+".txt\"")
                    .header(HttpHeaders.CONTENT_TYPE,"text/plain")
                    .contentLength(fileContent.length)
                    .contentType(MediaType.TEXT_PLAIN)
                    .body(fileContent);

        } catch (Exception e) {

            log.error("Error while downloading ascii file", e);

            throw new IllegalArgumentException(e.getMessage());
        }
    }

    private String buildFilePath(AsciiMaster master,AsciiFileRequest request) {
        
        if("branch".equalsIgnoreCase(request.getSearchBy())
        && (request.getBranchCode()==null 
        || request.getBranchCode().isBlank())){
            throw new IllegalArgumentException("Branch code is mandatory for branch search");
        }

        LocalDate reportDate=LocalDate.parse(request.getReportDate(),
        DateTimeFormatter.ofPattern("dd-MM-yyyy"));

        String dateFolder= reportDate.format(DateTimeFormatter.ofPattern("yyyy-MM-dd"));

        String fileDate= reportDate.format(DateTimeFormatter.ofPattern("yyyyMMdd"));

        String location = master.getLocation().replace("{date}", dateFolder);

        String branchCode = "bank".equalsIgnoreCase(request.getSearchBy())
                        ? "00000" : request.getBranchCode();

        log.info("report date:{}",dateFolder);
        log.info("location:{}",location);
        log.info("branch code:{}",branchCode);
        

        String fileName;

        if (request.getId() >= 101 && request.getId() <= 104) {

            AsciiConfig config = asciiConfigRepository.findById(request.getId())
                            .orElseThrow(() ->
                                    new IllegalArgumentException("ASCII Config not found"));

            if (config.getFileType() != null &&
                    !config.getFileType().isBlank()) {

                fileName = branchCode +"." +config.getOutputFileName() +"." +fileDate +"." +config.getFileType();
            }
            else {

                fileName = branchCode +"." +config.getOutputFileName() +"." +fileDate;
            }

        }
        else if (request.getId() >= 105 && request.getId() <= 107) {

            AsciiConfigTb configTb = asciiConfigTbRepository.findById(request.getId())
                            .orElseThrow(() ->
                                    new IllegalArgumentException("ASCII Config TB not found"));

            fileName = branchCode +"." +configTb.getFileIdentifier() +"." +fileDate;
        }
        else {

            throw new IllegalArgumentException("Invalid ASCII ID");
        }

        log.info("file name:{}",fileName);
        String  finalPath="/" + location + "/" + fileName;
        log.info("final path: {}",finalPath);
        log.info("Downloading file: {}",fileName);
        return finalPath;

    }
} 



