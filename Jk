import com.fincore.analyticsservice.repository.DrReportRepository;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.security.access.AccessDeniedException;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.*;

@Service
public class ReportConfigService {

    private static final Integer ROLE_ADMIN = 10;
    private static final Logger log = LoggerFactory.getLogger(ReportConfigService.class);
    private final DrReportRepository reportRepository;

    public ReportConfigService(DrReportRepository reportRepository) {
        this.reportRepository = reportRepository;
    }

    /**
     * Fetches UI metadata.
     * Caches the response by User Roles to ensure users only see their permitted views.
     */
    @Transactional(readOnly = true)
    @Cacheable(value = "uiReportConfig", key = "#roleId")
    public List<ReportConfigResponse> getPermittedConfigurations(Integer roleId) {
        log.info("Fetching Oracle UI configurations for roles: {}", roleId);

        List<DrReport> allActiveReports = reportRepository.findAllActiveReportsWithViews();
        List<ReportConfigResponse> permittedReports = new ArrayList<>();

        for (DrReport report : allActiveReports) {
            List<ViewConfig> permittedViews = processViews(report.getViews(), roleId);

            // Only return the report if the user has access to at least one view inside it
            if (!permittedViews.isEmpty()) {
                permittedReports.add(new ReportConfigResponse(
                        report.getReportCode(),
                        report.getDisplayName(),
                        permittedViews
                ));
            }
        }

        if (permittedReports.isEmpty()) {
            log.warn("User with role {} requested config but has zero report permissions.", roleId);
            throw new AccessDeniedException("You do not have permission to view any reports.");
        }

        return permittedReports;
    }

    private List<ViewConfig> processViews(Set<DrReportView> views, Integer roleId) {
        List<ViewConfig> permittedViews = new ArrayList<>();

        for (DrReportView view : views) {
            if (hasAccess(roleId, view.getRequiredRoleIds())) {

                // 1. Map Hierarchy (Must be strictly ordered by drillLevel)
                List<String> logicalHierarchy = view.getDimensions().stream()
                        .sorted(Comparator.comparing(DrViewDimension::getDrillLevel))
                        .map(DrViewDimension::getLogicalName)
                        .toList();

                // 2. Map Metrics
                List<MetricConfig> logicalMetrics = view.getMetrics().stream()
                        .map(m -> new MetricConfig(m.getLogicalName(), m.getDisplayName()))//Cannot resolve method 'getDisplayName' in 'DrViewMetric'
                        .toList();

                permittedViews.add(new ViewConfig(
                        view.getViewCode(),
                        // Assuming you have a displayName in DrReportView, otherwise use viewCode
                        view.getViewCode(),
                        logicalHierarchy,
                        logicalMetrics,
                        semanticDrillDownService.getAvailableDates(view.getViewCode(),roleId)
                ));
            }
        }
        return permittedViews;
    }

    private boolean hasAccess(Integer roleId, String requiredRoleIds) {
        // admin has access of everything
        if (ROLE_ADMIN.equals(roleId)) {
            return true;
        }

        // If no role is required, it's public. Otherwise, check user roles.
        if (requiredRoleIds == null || requiredRoleIds.isBlank() || "NULL".equalsIgnoreCase(requiredRoleIds.trim())) {
            return true;
        }

        List<String> allowedRoles = Arrays.asList(requiredRoleIds.split(","));

        // return true if allowed roles contains the role id
        return allowedRoles.contains(String.valueOf(roleId));
    }
}


