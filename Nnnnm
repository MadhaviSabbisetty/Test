String fileName;

if (request.getId() >= 101 && request.getId() <= 104) {

    AsciiConfig config =
            asciiConfigRepository.findById(request.getId())
                    .orElseThrow(() ->
                            new IllegalArgumentException(
                                    "ASCII Config not found"));

    if (config.getFileType() != null &&
            !config.getFileType().isBlank()) {

        fileName =
                branchCode +
                "." +
                config.getOutputFileName() +
                "." +
                fileDate +
                "." +
                config.getFileType();
    }
    else {

        fileName =
                branchCode +
                "." +
                config.getOutputFileName() +
                "." +
                fileDate;
    }

}
else if (request.getId() >= 105 && request.getId() <= 107) {

    AsciiConfigTb configTb =
            asciiConfigTbRepository.findById(request.getId())
                    .orElseThrow(() ->
                            new IllegalArgumentException(
                                    "ASCII Config TB not found"));

    fileName =
            branchCode +
            "." +
            configTb.getFileIdentifier() +
            "." +
            fileDate;
}
else {

    throw new IllegalArgumentException(
            "Invalid ASCII ID : " + request.getId());
}
