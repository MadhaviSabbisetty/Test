@Slf4j
@Service("TransactionsService")
@RequiredArgsConstructor
public class EnquiryServiceImpl implements EnquiryService {

	private final GlTransactionsRepository glTransactionsRepository;
	private final GLBalanceRepository glBalanceRepository;
	private final TransactionStreamingExportService transactionStreamingExportService;
	private final BalanceStreamingExportService balanceStreamingExportService;

	private static final String ZONE_IST = "Asia/Kolkata";

	@Override
	public PaginatedResponseDTO<GetResponseDTO> getTransactionsData(GetPayloadDTO dto) {

		String branch = dto.getBranch().split("-")[0];
		String currency = dto.getCurrency();
		String cgl = dto.getCgl();
		String fromDate = dto.getFromDate();
		String toDate = dto.getToDate();

		DateTimeFormatter formatter = DateTimeFormatter.ofPattern("dd/MM/yyyy");

		Double minAmount = dto.getMinAmount();
		Double maxAmount = dto.getMaxAmount();
		List<String> sourceFlag = dto.getSourceFlags();
		int applySourceFlag = 1;

		LocalDate formattedFromDate = LocalDate.parse(fromDate, formatter);
		LocalDate formattedToDate = LocalDate.parse(toDate, formatter);

		LocalDate fromMinusOneDay = formattedFromDate.minusDays(1);

		GLBalance openingGLBalance = glBalanceRepository
				.getGlBalanceData(fromMinusOneDay.format(formatter), branch, currency, cgl);

		GLBalance closingGLBalance = glBalanceRepository
				.getGlBalanceData(formattedToDate.format(formatter), branch, currency, cgl);

		PaginatedResponseDTO<GetResponseDTO> response = new PaginatedResponseDTO<>();

		if (openingGLBalance == null || closingGLBalance == null) {
			response.setData(Collections.emptyList());
			return response;
		}

		if (sourceFlag == null || sourceFlag.isEmpty() || sourceFlag.contains("ALL")) {
			applySourceFlag = 0;
			sourceFlag = List.of("NA");
		}

		if (minAmount != null && maxAmount != null && minAmount > maxAmount) {
			throw new IllegalArgumentException("minAmount cannot be greater than maxAmount");
		}

		int page = (dto.getPage() == null || dto.getPage() < 0) ? 0 : dto.getPage();
		int size = (dto.getSize() == null || dto.getSize() <= 0) ? 10 : dto.getSize();

		String sortBy = dto.getSortBy() != null
				? dto.getSortBy()
				: "TRANSACTION_DATE";

		String sortIn = dto.getSortIn() != null
				? dto.getSortIn()
				: "ASC";

		Sort.Direction direction = sortIn.equalsIgnoreCase("DESC")
				? Sort.Direction.DESC
				: Sort.Direction.ASC;

		Sort sort = Sort.by(direction, sortBy)
				.and(Sort.by("TRANSACTION_ID"));

		Pageable pageable = PageRequest.of(page, size, sort);

		Page<GlTransactions> pageResult = glTransactionsRepository.getData(
				branch,
				currency,
				cgl,
				fromDate,
				toDate,
				minAmount,
				maxAmount,
				sourceFlag,
				applySourceFlag,
				pageable);

		List<GetResponseDTO> responseList = new ArrayList<>();

		for (GlTransactions txn : pageResult.getContent()) {
			responseList.add(mapToResponseDTO(txn, formatter));
		}

		response.setCurrentPage(page);
		response.setTotalPages(pageResult.getTotalPages());
		response.setPageSize(size);
		response.setTotalElements(pageResult.getTotalElements());
		response.setData(responseList);

		Map<String, Object> extra = new HashMap<>();
		extra.put("openingBalance", openingGLBalance.getBalance());
		extra.put("closingBalance", closingGLBalance.getBalance());
		extra.put("openingDate", formatter.format(formattedFromDate));
		extra.put("closingDate", formatter.format(formattedToDate));

		response.setExtraData(extra);

		return response;
	}


	@Override
	public byte[] getTransactionsFile(
			GetPayloadDTO dto,
			String userId)
			throws IOException {

		String branch = dto.getBranch().split("-")[0];

		String currency = dto.getCurrency();

		String cgl = dto.getCgl().split(" -")[0];

		DateTimeFormatter formatter = DateTimeFormatter.ofPattern("dd/MM/yyyy");

		LocalDate fromDate = LocalDate.parse(
				dto.getFromDate(),
				formatter);

		LocalDate toDate = LocalDate.parse(
				dto.getToDate(),
				formatter);

		GLBalance openingBalance = glBalanceRepository.getGlBalanceData(
				fromDate.minusDays(1).format(formatter),
				branch,
				currency,
				cgl);

		GLBalance closingBalance = glBalanceRepository.getGlBalanceData(
				toDate.format(formatter),
				branch,
				currency,
				cgl);

		return transactionStreamingExportService.export(
				dto,
				openingBalance,
				closingBalance,
				userId);
	}

	@Override
	public PaginatedResponseDTO<BalanceResponseDTO> getBalanceDetails(BalanceRequestDTO request) {
		if (request.getEndDate().before(request.getStartDate())) {
			log.error("End date must be after start date.");
			throw new IllegalArgumentException("End date must be after start date");
		}

		// 1. Force Start Date to 00:00:00 IST
		Date adjustedStartDate = convertToStartOfDay(request.getStartDate());
		// 2. Force End Date to 23:59:59 IST
		Date adjustedEndDate = convertToEndOfDay(request.getEndDate());

		int page = (request.getPage() != null && request.getPage() >= 0) ? request.getPage() : 0;
		int size = (request.getSize() != null && request.getSize() >= 0) ? request.getSize() : 10;

		String sortIn = (request.getSortIn() != null && !request.getSortIn().isBlank())
				? request.getSortIn().toUpperCase()
				: "ASC";

		Sort sort = sortIn.equals("DESC") ? Sort.by("date").descending() : Sort.by("date").ascending();
		PageRequest pageRequest = PageRequest.of(page, size, sort);

		log.info("Adjusted Start Date : {}", adjustedStartDate);
		log.info("Adjusted End Date : {}", adjustedEndDate);

		Page<GLBalance> records = glBalanceRepository.findByBranchAndCglAndCurrencyAndDateBetween(
				request.getBranch(), request.getCgl(), request.getCurrency(),
				adjustedStartDate, adjustedEndDate,
				pageRequest);

		if (records.isEmpty()) {
			log.warn("No records found for the given filters.");
			throw new NoDataFoundException("No records found for given filters");
		}

		List<BalanceResponseDTO> list = records.stream()
				.map(r -> new BalanceResponseDTO(
						r.getId(), r.getDate(), r.getBranch(), r.getCgl(), r.getCurrency(), r.getBalance(),
						r.getBalance() < 0 ? "DR" : "CR"))
				.toList();

		String actualSort = records.getSort().stream().findFirst().map(order -> order.getDirection().name())
				.orElse("UNSORTED");

		return new PaginatedResponseDTO<>(
				records.getNumber(), records.getTotalPages(), records.getSize(), records.getTotalElements(), actualSort,
				list, null);
	}


	@Override
	public byte[] exportBalanceToExcel(
			BalanceRequestDTO request,
			String userId) {

		return balanceStreamingExportService.export(
				request, userId);
	}

	@Override
	public PaginatedResponseDTO<GlTransactionResponseDTO> getGlTransactionsReport(
			String startDate, String endDate, String circle, String branch, String cgl, Integer page, Integer size,
			String currency) {

		int pageNo = (page != null && page >= 0) ? page : 0;
		int pageSize = (size != null && size > 0) ? size : 10;
		Pageable pageable = PageRequest.of(pageNo, pageSize);

		Page<GlTransactionProjection> pageResult = glTransactionsRepository.findGlTransactions(
				startDate, endDate, currency, circle, branch, cgl, pageable);

		List<GlTransactionResponseDTO> list = pageResult.getContent().stream()
				.map(this::toGlTransactionDto)
				.toList();

		if (list.isEmpty()) {
			log.warn("No transactions found for the given criteria.");
			throw new NoDataFoundException("No records found for the given criteria");
		}

		return new PaginatedResponseDTO<>(
				pageResult.getNumber(),
				pageResult.getTotalPages(),
				pageResult.getSize(),
				pageResult.getTotalElements(),
				null,
				list, null);
	}

	private GlTransactionResponseDTO toGlTransactionDto(GlTransactionProjection p) {
		return new GlTransactionResponseDTO(
				p.getCIRCLE_CODE(),
				p.getCIRCLE_NAME(),
				p.getBRANCH_NAME(),
				p.getBRANCH_CODE(),
				p.getCGL(),
				p.getCGL_DESCRIPTION(),
				p.getNARRATION(),
				p.getTRANSACTION_DATE(),
				p.getCURRENCY(),
				p.getTOTAL_DEBIT(),
				p.getTOTAL_CREDIT());
	}

	@Override
	public PaginatedResponseDTO<GLBalanceResponseDTO> getGlBalanceReport(
			String startDate, String endDate, String circle, String branch, String cgl, Integer page, Integer size,
			String currency) {

		Pageable pageable = PageRequest.of(page != null ? page : 0, size != null ? size : 10);

		Page<GLBalanceProjection> pageResult = glBalanceRepository.findGlBalances(
				startDate, endDate, currency, circle, branch, cgl, pageable);

		List<GLBalanceResponseDTO> list = pageResult.getContent().stream()
				.map(this::toGlBalanceDto)
				.toList();

		return new PaginatedResponseDTO<>(
				pageResult.getNumber(),
				pageResult.getTotalPages(),
				pageResult.getSize(),
				pageResult.getTotalElements(),
				null,
				list, null);
	}

	// =========================================================
	// PRIVATE HELPER METHODS
	// =========================================================

	private GetResponseDTO mapToResponseDTO(
			GlTransactions txn,
			DateTimeFormatter formatter) {

		GetResponseDTO res = new GetResponseDTO();

		res.setDate(formatter.format(txn.getTransactionDate()));
		res.setJournalNumber(txn.getJournalId());
		res.setBatchId(txn.getBatchId());
		res.setSourceFlag(
				SourceFlagUtil.getSourceFlagDescription(
						txn.getSourceFlag()));

		res.setTransactionCount(txn.getTransactionCount());
		res.setParticulars(txn.getNarration());
		res.setPostDate(txn.getPostDate().toLocalDateTime());
		res.setTransactionId(txn.getTransactionId());

		double debit = txn.getDebitAmount() != null ? Math.abs(txn.getDebitAmount()) : 0;
		double credit = txn.getCreditAmount() != null ? Math.abs(txn.getCreditAmount()) : 0;

		res.setDebitAmount(debit);
		res.setCreditAmount(credit);

		return res;
	}

	/**
	 * Helper Method: Forces the date to Start of Day (00:00:00) in Asia/Kolkata
	 * regardless of Server TimeZone.
	 */
	private Date convertToStartOfDay(Date date) {
		if (date == null)
			return null;
		Calendar calendar = Calendar.getInstance(TimeZone.getTimeZone(ZONE_IST));
		calendar.setTime(date);
		calendar.set(Calendar.HOUR_OF_DAY, 0);
		calendar.set(Calendar.MINUTE, 0);
		calendar.set(Calendar.SECOND, 0);
		calendar.set(Calendar.MILLISECOND, 0);
		return calendar.getTime();
	}

	/**
	 * Helper Method: Forces the date to End of Day (23:59:59) in Asia/Kolkata
	 * regardless of Server TimeZone.
	 */
	private Date convertToEndOfDay(Date date) {
		if (date == null)
			return null;
		Calendar calendar = Calendar.getInstance(TimeZone.getTimeZone(ZONE_IST));
		calendar.setTime(date);
		calendar.set(Calendar.HOUR_OF_DAY, 23);
		calendar.set(Calendar.MINUTE, 59);
		calendar.set(Calendar.SECOND, 59);
		calendar.set(Calendar.MILLISECOND, 999);
		return calendar.getTime();
	}

	private GLBalanceResponseDTO toGlBalanceDto(GLBalanceProjection p) {
		return new GLBalanceResponseDTO(
				p.getCIRCLE_CODE(),
				p.getCIRCLE_NAME(),
				p.getBRANCH_NAME(),
				p.getBRANCH_CODE(),
				p.getCGL(),
				p.getCGL_DESCRIPTION(),
				p.getBALANCE_DATE(),
				p.getCURRENCY(),
				p.getTOTAL_BALANCE(),
				p.getTOTAL_INR_BALANCE());
	}
}
