    @Override
    public AsciiFileResponse viewAscii(AsciiFileRequest request) {

        try {

            log.info("ASCII VIEW REQUEST : {}", request);

            AsciiMaster master =
                    asciiMasterRepository.findById(request.getId())
                            .orElseThrow(() ->
                                    new IllegalArgumentException("Invalid ASCII ID"));

            String hdfsPath = buildFilePath(master, request);

            log.info("FINAL HDFS PATH : {}", hdfsPath);

            FileSystem fs = hdfsService.getFs();

            Path path = new Path(hdfsPath);
            log.info("checking file existence....");

            boolean fileExists=fs.exists(path);
            log.info("file exists:{}",fileExists);

            // if(!fileExists){
            //     AsciiFileResponse response=new AsciiFileResponse();
            //     response.setId(request.getId());
            //     response.setReportDate(request.getReportDate());
            //     response.setSearchBy(request.getSearchBy());

            //     if("branch".equalsIgnoreCase(request.getSearchBy())){
            //         response.setBranchCode(request.getBranchCode());
            //     }
            //     response.setContent("ASCII File not found");
            //     return response;
            if (!fs.exists(path)) {
               throw new IllegalArgumentException("ASCII File not found");
            }

            StringBuilder content = new StringBuilder();

            try (FSDataInputStream inputStream = fs.open(path);
                 BufferedReader reader =
                         new BufferedReader(new InputStreamReader(inputStream))) {

                String line;

                while ((line = reader.readLine()) != null) {
                    content.append(line)
                           .append(System.lineSeparator());
                }
            }

            AsciiFileResponse response = new AsciiFileResponse();

            response.setId(request.getId());
            response.setReportDate(request.getReportDate());
            response.setSearchBy(request.getSearchBy());

            if ("branch".equalsIgnoreCase(request.getSearchBy())) {
                response.setBranchCode(request.getBranchCode());
            }

            response.setContent(content.toString());

            return response;

        } catch (Exception e) {

            log.error("Error while viewing ascii file", e);

            throw new IllegalArgumentException(e.getMessage());
        }
    }

    @Override
    public ResponseEntity<byte[]> downloadAscii(AsciiFileRequest request) {

        try {

            AsciiMaster master =
                    asciiMasterRepository.findById(request.getId())
                            .orElseThrow(() ->
                                    new IllegalArgumentException("Invalid ASCII ID"));

            String hdfsPath = buildFilePath(master, request);

            FileSystem fs = hdfsService.getFs();

            Path path = new Path(hdfsPath);

            if (!fs.exists(path)) {
                throw new IllegalArgumentException("Failed to download. ASCII File not found");
            }

            FSDataInputStream inputStream = fs.open(path);

            byte[] fileContent =
                    inputStream.readAllBytes();

            inputStream.close();

            String fileName = path.getName();

            return ResponseEntity.ok()
                    .header(
                            HttpHeaders.CONTENT_DISPOSITION,
                            "attachment; filename=" + fileName)
                    .contentType(MediaType.TEXT_PLAIN)
                    .body(fileContent);

        } catch (Exception e) {

            log.error("Error while downloading ascii file", e);

            throw new IllegalArgumentException(e.getMessage());
        }
    }

