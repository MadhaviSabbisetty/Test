package com.fincore.analyticsservice.client;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.core.ParameterizedTypeReference;
import org.springframework.http.MediaType;
import org.springframework.http.client.JdkClientHttpRequestFactory;
import org.springframework.stereotype.Component;
import org.springframework.web.client.RestClient;

import javax.net.ssl.SSLContext;
import javax.net.ssl.TrustManager;
import javax.net.ssl.X509TrustManager;
import java.net.http.HttpClient;
import java.security.KeyManagementException;
import java.security.NoSuchAlgorithmException;
import java.security.SecureRandom;
import java.security.cert.X509Certificate;
import java.util.List;
import java.util.Map;

/**
 * Enterprise Apache Druid Rest Client upgraded with SSL capabilities.
 * Configured using Java 21 Native HTTP client to gracefully handle
 * secure HTTPS and self-signed certificates on internal developer subnets.
 */
@Component
public class DruidRestClient {

    private static final Logger log = LoggerFactory.getLogger(DruidRestClient.class);
    private final RestClient restClient;

    public DruidRestClient(
            RestClient.Builder restClientBuilder,
            @Value("${druid.router.url:https://10.177.103.194:8282}") String druidUrl) {

        log.info("Initializing Druid REST Client targeting secure endpoint: [{}]", druidUrl);

        // Build a secure Java 21 request factory that accepts internal corporate self-signed SSL certificates
        JdkClientHttpRequestFactory requestFactory = new JdkClientHttpRequestFactory(createSslConfiguredHttpClient());

        this.restClient = restClientBuilder
                .requestFactory(requestFactory)
                .baseUrl(druidUrl)
                .defaultHeader("Content-Type", MediaType.APPLICATION_JSON_VALUE)
                .defaultHeader("Accept", MediaType.APPLICATION_JSON_VALUE)
                .build();
    }

    /**
     * Executes the compiled SQL payload securely against Druid via HTTPS.
     */
    public List<Map<String, Object>> executeQuery(Map<String, Object> druidSqlPayload) {
        log.debug("Executing SSL Druid Query: {}", druidSqlPayload);

        return restClient.post()
                .uri("/druid/v2/sql")
                .body(druidSqlPayload)
                .retrieve()
                .body(new ParameterizedTypeReference<List<Map<String, Object>>>() {});
    }

    /**
     * Creates an HttpClient instance bypassing standard public CA certification paths.
     * Perfect for internal dev boxes (10.x.x.x) using self-signed certs.
     */
    private HttpClient createSslConfiguredHttpClient() {
        try {
            // Create a trust manager that does not validate certificate chains
            TrustManager[] trustAllCerts = new TrustManager[]{
                    new X509TrustManager() {
                        public X509Certificate[] getAcceptedIssuers() {
                            return new X509Certificate[0];
                        }
                        public void checkClientTrusted(X509Certificate[] certs, String authType) {}
                        public void checkServerTrusted(X509Certificate[] certs, String authType) {}
                    }
            };

            // Install the all-trusting trust manager
            SSLContext sslContext = SSLContext.getInstance("TLS");
            sslContext.init(null, trustAllCerts, new SecureRandom());

            return HttpClient.newBuilder()
                    .sslContext(sslContext)
                    .build();

        } catch (NoSuchAlgorithmException | KeyManagementException e) {
            log.error("Fatal Error initializing Druid REST Client SSL Context", e);
            throw new IllegalStateException("Failed to configure secure transport layer for Druid client.", e);
        }
    }
}

